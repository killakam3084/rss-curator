#!/bin/bash
# RSS Curator Configuration
# Copy this file to ~/.curator.env and customize for your setup

# ============================================================================
# REQUIRED: RSS Feed URL from your private tracker
# ============================================================================
export RSS_FEED_URL="https://your-tracker.com/rss?passkey=YOUR_PASSKEY_HERE"
# Optional: separate movie RSS feed (items tagged content_type=movie automatically)
export RSS_MOVIE_FEED_URL=""

# ============================================================================
# REQUIRED: qBittorrent Web UI credentials
# ============================================================================
export QBITTORRENT_HOST="http://localhost:8080"
export QBITTORRENT_USER="admin"
export QBITTORRENT_PASS="your-password-here"

# ============================================================================
# OPTIONAL: qBittorrent download settings
# ============================================================================
# Category to use for curator downloads
export QBITTORRENT_CATEGORY="curator"

# Save path for downloads (leave empty to use qBittorrent's default)
# export QBITTORRENT_SAVEPATH="/path/to/downloads"

# Add torrents in paused state (default: true during testing)
# Set to false to auto-start downloads
export QBITTORRENT_ADD_PAUSED="true"

# ============================================================================
# OPTIONAL: Show matching rules
# ============================================================================
# Comma-separated list of shows to watch for
# Matching is case-insensitive and uses substring matching
export SHOW_NAMES="The Last of Us,Foundation,Severance,House of the Dragon"

# ============================================================================
# OPTIONAL: Quality preferences
# ============================================================================
# Minimum quality: 720p, 1080p, or 2160p
export MIN_QUALITY="1080p"

# Preferred codec: x264, x265, or HEVC
export PREFERRED_CODEC="x265"

# ============================================================================
# OPTIONAL: Release group preferences
# ============================================================================
# Comma-separated list of preferred release groups
# Items from these groups will be highlighted in match reasons
export PREFERRED_GROUPS="NTb,FLUX,HMAX,CMRG,NOSiViD,ETHEL"

# Comma-separated list of release groups to exclude
# Items from these groups will never be matched
export EXCLUDE_GROUPS="YIFY,RARBG"

# ============================================================================
# OPTIONAL: Storage location
# ============================================================================
# Path to SQLite database (default: ~/.curator.db)
# export STORAGE_PATH="$HOME/.curator.db"

# ============================================================================
# OPTIONAL: AI/ML scoring (Ollama or OpenAI-compatible or Anthropic)
# ============================================================================
# Provider: "ollama" (default, self-hosted), "openai" (cloud/compatible),
#           "anthropic" (Claude), or "disabled"
# export CURATOR_AI_PROVIDER=ollama

# Base URL of the inference server (Ollama / OpenAI-compatible only)
# export CURATOR_AI_HOST=http://localhost:11434

# Model name to use for all subsystems (enricher, scorer, suggester) unless overridden
# Ollama default: llama3.2  |  OpenAI default: gpt-4o-mini  |  Anthropic default: claude-haiku-3-5
# export CURATOR_AI_MODEL=llama3.2

# Per-subsystem model overrides — each falls back to CURATOR_AI_MODEL if unset.
# Recommended: use a small/fast model for enrichment, a mid-size model for scoring,
# and reserve the largest model for the suggestion engine (on-demand, not per-item).
# export CURATOR_AI_ENRICHER_MODEL=llama3.2:1b
# export CURATOR_AI_SCORER_MODEL=llama3.2
# export CURATOR_AI_SUGGESTER_MODEL=llama3.1:8b

# Per-subsystem provider overrides — mix local and cloud inference.
# Example: run Ollama locally for enrichment/scoring, Anthropic only for suggestions.
#   Resolution order per setting: CURATOR_AI_{SUBSYSTEM}_{VAR} → CURATOR_AI_{VAR} → default
# export CURATOR_AI_SUGGESTER_PROVIDER=anthropic
# export CURATOR_AI_SUGGESTER_KEY=sk-ant-...
# (leave CURATOR_AI_PROVIDER=ollama to keep enricher + scorer on local Ollama)

# API key — required for "anthropic" and "openai" providers
# Anthropic: API key from console.anthropic.com/settings/keys
# OpenAI:    API key from platform.openai.com/api-keys
# export CURATOR_AI_KEY=

# Number of past activity entries sampled into the scoring prompt (default: 40)
# export CURATOR_AI_HISTORY_SIZE=40

# Per-request inference timeout in seconds for scoring and enrichment (default: 60)
# Increase if your local model (e.g. Ollama) consistently exceeds the default.
# export CURATOR_AI_TIMEOUT_SECS=60

# Ollama context window (KV cache size). Curator prompts are ~400 tokens;
# 2048 is generous headroom with far lower cost than Ollama's 128K default.
# export CURATOR_AI_NUM_CTX=2048

# Ollama max tokens to generate per request. Scorer output is ~80-100 tokens
# of JSON; 400 is safe headroom. Increase for enricher/suggester if needed.
# export CURATOR_AI_NUM_PREDICT=400

# ============================================================================
# OPTIONAL: TV metadata enrichment
# ============================================================================
# Provider: "tvmaze" (default, free, no key), "tmdb", "tvdb", or "disabled".
# TVMaze is the recommended default — no API key required.
# export CURATOR_META_PROVIDER=tvmaze

# API key — required for tmdb and tvdb; unused by tvmaze.
# export CURATOR_META_KEY=

# Override the provider base URL (e.g. for a local mirror or proxy).
# export CURATOR_META_HOST=

# How long (hours) a cached metadata record is considered fresh before the
# provider is queried again (default: 168 = 7 days).
# export CURATOR_META_TTL_HOURS=168

# Explicit path for the metadata cache database. When unset, curator-meta.db
# is placed in the same directory as the main STORAGE_PATH database so both
# files always land on the same container volume / dataset automatically.
# export CURATOR_META_DB=/data/curator-meta.db

# ============================================================================
# OPTIONAL: API server
# ============================================================================
# Port for the HTTP API / web UI (default: 8081)
# export CURATOR_API_PORT=8081

# ============================================================================
# OPTIONAL: In-app authentication
# ============================================================================
# Set CURATOR_PASSWORD to enable the login page and protect the web UI.
# When unset, the app is accessible without credentials (local-dev default).
#
# Username shown on the login prompt (default: "curator")
# export CURATOR_USERNAME=curator
#
# Password for the web UI — auth is disabled when this is unset
# export CURATOR_PASSWORD=your-password-here
#
# HMAC signing key for session tokens.
# If unset a random key is generated at startup (sessions won't survive restarts).
# Set this explicitly when running behind a reverse proxy or in a container.
# export CURATOR_SESSION_SECRET=change-me-to-a-long-random-string
#
# Session lifetime in hours (default: 24)
# export CURATOR_SESSION_TTL_HOURS=24

# ============================================================================
# Usage:
# ============================================================================
# 1. Copy this file: cp curator.env.sample ~/.curator.env
# 2. Edit with your settings: vim ~/.curator.env
# 3. Source before running: source ~/.curator.env
# 4. Run curator: curator check
#
# Or create an alias in ~/.bashrc:
#   alias curator='source ~/.curator.env && curator'
