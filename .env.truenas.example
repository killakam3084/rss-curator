# Required secrets for rss-curator on TrueNAS.
# Copy to .env (gitignored), or store in Infisical and inject via:
#   infisical run --projectId=<id> --env=prod -- docker compose -f docker-compose.truenas.yml up -d

# Anthropic API key for suggester
CURATOR_AI_SUGGESTER_KEY=sk-ant-api03-...

# TMDB JWT bearer token
CURATOR_META_KEY=eyJhbGci...

# Curator web UI credentials
CURATOR_PASSWORD=changeme
CURATOR_SESSION_SECRET=<64-char hex string>

# qBittorrent password
QBITTORRENT_PASS=changeme

# iptorrents RSS feed URLs (contain tracker passkey — treat as secret)
RSS_FEED_URL=https://iptorrents.com/t.rss?u=...;tp=...;...;download
RSS_MOVIE_FEED_URL=https://iptorrents.com/t.rss?u=...;tp=...;...;download
