# Local development environment — copy to local.env and fill in your values
# local.env is gitignored; never commit real credentials

# ── RSS feed ──────────────────────────────────────────────────────────────
RSS_FEED_URL=https://your-tracker.com/rss?passkey=YOUR_PASSKEY_HERE

# ── qBittorrent ───────────────────────────────────────────────────────────
# If qBittorrent is running on your host machine, use host.containers.internal
# (Podman's DNS alias for the host from inside a container on macOS/Windows)
QBITTORRENT_HOST=http://host.containers.internal:8080
QBITTORRENT_USER=admin
QBITTORRENT_PASS=your-password-here
QBITTORRENT_CATEGORY=curator

# Add torrents paused during dev so nothing accidentally downloads
QBITTORRENT_ADD_PAUSED=true

# ── Scheduler & API ───────────────────────────────────────────────────────
CHECK_INTERVAL=3600
CURATOR_API_PORT=8081
